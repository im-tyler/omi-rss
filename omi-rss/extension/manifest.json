{
  "manifest_version": 3,
  "name": "Omi RSS Reader",
  "version": "1.0.0",
  "description": "Save articles, generate RSS feeds, and read your feeds from anywhere",
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "notifications",
    "sidePanel"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "action": {
    "default_popup": "popup-redesigned.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Omi RSS Reader - Click to open"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "js/offline-db.js",
        "js/extractors/site-specific.js",
        "js/content.js"
      ],
      "css": ["css/content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["css/inject.css", "js/inject.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "save-article": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Save current article"
    },
    "toggle-reader": {
      "suggested_key": {
        "default": "Ctrl+Shift+R",
        "mac": "Command+Shift+R"
      },
      "description": "Toggle reader mode"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html",
    "default_title": "RSS Reader"
  }
}