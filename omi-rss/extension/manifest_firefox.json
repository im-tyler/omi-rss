{
  "manifest_version": 3,
  "name": "Omi RSS Reader",
  "version": "1.0.0",
  "description": "Save articles, generate RSS feeds, and read your feeds from anywhere",
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "notifications",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "scripts": ["js/background.js"],
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/content.js"],
      "css": ["css/content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["css/inject.css", "js/inject.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "save-article": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Save current article"
    },
    "toggle-reader": {
      "suggested_key": {
        "default": "Ctrl+Shift+R",
        "mac": "Command+Shift+R"
      },
      "description": "Toggle reader mode"
    },
    "open-sidepanel": {
      "suggested_key": {
        "default": "Ctrl+Shift+O",
        "mac": "Command+Shift+O"
      },
      "description": "Open RSS Reader Panel"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "omi-rss@example.com",
      "strict_min_version": "109.0"
    }
  }
}