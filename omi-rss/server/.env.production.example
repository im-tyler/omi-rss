# Node Environment
NODE_ENV=production
PORT=3000

# Database
DATABASE_URL=postgresql://omi_user:your_secure_password@postgres:5432/omi_rss
POSTGRES_DB=omi_rss
POSTGRES_USER=omi_user
POSTGRES_PASSWORD=your_secure_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# JWT & Security
JWT_SECRET=your-very-long-random-string-here
JWT_EXPIRY=7d
REFRESH_TOKEN_EXPIRY=30d

# CORS
CORS_ORIGIN=https://your-domain.com,https://app.your-domain.com

# Domain
DOMAIN_NAME=your-domain.com

# Email Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@your-domain.com

# OAuth Providers
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# AI Services
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GOOGLE_AI_API_KEY=your-google-ai-key

# Market Data Providers
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key
FINNHUB_API_KEY=your-finnhub-key
YAHOO_FINANCE_ENABLED=true

# Push Notifications - Firebase
FCM_PROJECT_ID=your-firebase-project-id
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FCM_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# Push Notifications - Web Push
WEB_PUSH_PUBLIC_KEY=your-vapid-public-key
WEB_PUSH_PRIVATE_KEY=your-vapid-private-key
WEB_PUSH_EMAIL=mailto:admin@your-domain.com

# Push Notifications - Expo (optional)
EXPO_ACCESS_TOKEN=your-expo-access-token

# File Storage
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# Monitoring
GRAFANA_PASSWORD=your-grafana-password
PROMETHEUS_ENABLED=true

# Logging
LOG_LEVEL=info
LOG_FILE=/app/logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=7
LOG_COMPRESS=true

# Sentry (Error Tracking)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production

# Feature Flags
FEATURE_AI_SUMMARIES=true
FEATURE_MARKET_DATA=true
FEATURE_PUSH_NOTIFICATIONS=true
FEATURE_COLLABORATION=true
FEATURE_CONTENT_GENERATION=true

# Performance
ENABLE_QUERY_LOGGING=false
ENABLE_REQUEST_LOGGING=true
CACHE_TTL=3600

# Backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 3 * * *"
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your-backup-bucket
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1